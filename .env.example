# ================================
# TRENDALPHA — ENV CONFIG
# ================================

# TELEGRAM
# 1. Message @BotFather on Telegram
# 2. Send /newbot and follow the steps
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_SAFE_MODE=true

# Channel ID — add your bot as admin to your channel
# then forward a message from the channel to @userinfobot to get the ID
# it will look like -100xxxxxxxxxx
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# SUPABASE (free tier at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

# DEXSCREENER — no key needed, free API

# BIRDEYE (free tier at birdeye.so/developers)
BIRDEYE_API_KEY=your_birdeye_key_here

# SCAN CONFIG
SCAN_INTERVAL_MINUTES=15
MIN_SCORE_TO_ALERT=60
MIN_LAUNCH_SCORE=82
ENABLE_LAUNCH_CANDIDATES=true
MEMORY_ONLY_LAUNCH_TEST_MODE=false
ENABLE_REAL_LAUNCHES=false
ENABLE_LIVE_LAUNCH_FROM_SCAN=false
DEPLOYMENT_MIN_LAUNCH_READINESS=80
DEPLOYMENT_MAX_SWARM_PRESSURE=40
OINK_GLOBAL_LAUNCH_DISABLE=false
MAX_LAUNCHES_PER_HOUR=3
SAME_NARRATIVE_SUPPRESSION_HOURS=24
TICKER_COLLISION_COOLDOWN_HOURS=72
PUMPPORTAL_API_BASE_URL=https://pumpportal.fun/api
PUMPPORTAL_API_KEY=
PUMPPORTAL_CREATE_AMOUNT_SOL=0.0001
PUMPPORTAL_SLIPPAGE=10
PUMPPORTAL_PRIORITY_FEE_SOL=0.00001
PUMPPORTAL_POOL=pump
VANITY_MINT_SUFFIX=oink
VANITY_MINT_MAX_ATTEMPTS=15000000
VANITY_MINT_TIMEOUT_MS=30000
VANITY_MINT_CASE_INSENSITIVE=true
VANITY_MINT_REQUIRE_MATCH=true
CREATOR_FEE_SWEEP_INTERVAL_HOURS=24
CREATOR_FEE_PRIORITY_FEE_SOL=0.00001
CREATOR_FEE_POOLS=pump|meteora-dbc
PINATA_JWT=
SOLANA_RPC_URL=
SOLANA_CONFIRMATION_TIMEOUT_MS=60000
SOLANA_CONFIRMATION_POLL_MS=2500
SIGNER_DISABLED=true
DEPLOY_WALLET_PUBLIC_KEY=
# Optional only. Store in Railway secret env if live signing is intentionally tested later.
# Never commit a funded key. Signing still requires ENABLE_REAL_LAUNCHES=true and SIGNER_DISABLED=false.
DEPLOY_WALLET_PRIVATE_KEY=
TREASURY_WALLET_PUBLIC_KEY=
FEE_WALLET_PUBLIC_KEY=
MONITORING_WALLET_PUBLIC_KEY=
DEPLOY_WALLET_KEY_STUB=
TREASURY_WALLET_KEY_STUB=
FEE_WALLET_KEY_STUB=
MONITORING_WALLET_KEY_STUB=
OINK_TWITTER_URL=https://x.com/oink
OINK_TELEGRAM_URL=https://t.me/oink
OINK_WEBSITE_URL=https://oink.bot
IMAGE_ASSET_MODE=placeholder
IMAGE_ASSET_LOCAL_PATH=
IMAGE_ASSET_REMOTE_URL=
ENABLE_SOURCE_MEDIA_HOTLINK=false
METADATA_UPLOAD_PROVIDER=dry_wire
METADATA_ASSET_BASE_URL=https://assets.oink.bot/dry-wire
METADATA_JSON_BASE_URL=https://assets.oink.bot/dry-wire/metadata
METADATA_DOWNLOAD_REMOTE_IMAGES=true
LIVE_METADATA_STRICT_MODE=false
ASSET_HOSTING_PROVIDER=local
HOSTED_ASSET_BASE_URL=https://assets.oink.bot/local
ASSET_LOCAL_DIR=.oink-assets
ASSET_UPLOAD_RETRIES=2
ENABLE_EXISTING_TOKEN_MATCHING=true
TOKEN_MATCH_CONFIDENCE_THRESHOLD=0.90
TOKEN_POSSIBLE_THRESHOLD=0.50
X_LAUNCH_IF_NO_MARKET=true

# ATTENTION PROVIDERS
ENABLE_TIKTOK_PROVIDER=true
ENABLE_X_PROVIDER=true

# X API
X_BEARER_TOKEN=
# Optional: separate custom recent-search queries with |
X_SEARCH_QUERIES=
X_MIN_SHARE_VELOCITY=100
X_MIN_QUOTE_VELOCITY=25
X_MIN_REPOST_VELOCITY=75
X_MIN_QUOTE_ACCELERATION=3
X_MIN_REPOST_ACCELERATION=3
X_MIN_QUOTE_RATE=0.35
X_MIN_QUOTE_TO_LIKE_RATE=0.08
X_MIN_VIEWS_PER_HOUR=50000
X_MIN_ENGAGEMENT_PER_HOUR=250
X_MIN_ENGAGEMENT_ACCELERATION=500
X_MIN_ATTENTION_SHAPE_SCORE=25000
X_MIN_SCOUT_SHAPE_SCORE=500
X_MAX_SCOUT_POSTS_PER_QUERY=1
X_MAX_POST_AGE_HOURS=12
X_MAX_STRONG_POST_AGE_HOURS=48
X_RESULTS_PER_QUERY=25
