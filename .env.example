# ================================
# TRENDALPHA — ENV CONFIG
# ================================

# TELEGRAM
# 1. Message @BotFather on Telegram
# 2. Send /newbot and follow the steps
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Channel ID — add your bot as admin to your channel
# then forward a message from the channel to @userinfobot to get the ID
# it will look like -100xxxxxxxxxx
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# SUPABASE (free tier at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

# DEXSCREENER — no key needed, free API

# BIRDEYE (free tier at birdeye.so/developers)
BIRDEYE_API_KEY=your_birdeye_key_here

# SCAN CONFIG
SCAN_INTERVAL_MINUTES=15
MIN_SCORE_TO_ALERT=60
