# ================================
# TRENDALPHA — ENV CONFIG
# ================================

# TELEGRAM
# 1. Message @BotFather on Telegram
# 2. Send /newbot and follow the steps
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Channel ID — add your bot as admin to your channel
# then forward a message from the channel to @userinfobot to get the ID
# it will look like -100xxxxxxxxxx
TELEGRAM_CHANNEL_ID=-100xxxxxxxxxx

# SUPABASE (free tier at supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here

# DEXSCREENER — no key needed, free API

# BIRDEYE (free tier at birdeye.so/developers)
BIRDEYE_API_KEY=your_birdeye_key_here

# SCAN CONFIG
SCAN_INTERVAL_MINUTES=15
MIN_SCORE_TO_ALERT=60
MIN_LAUNCH_SCORE=82
ENABLE_LAUNCH_CANDIDATES=true

# ATTENTION PROVIDERS
ENABLE_TIKTOK_PROVIDER=true
ENABLE_X_PROVIDER=true

# X API
X_BEARER_TOKEN=
# Optional: separate custom recent-search queries with |
X_SEARCH_QUERIES=
X_MIN_SHARE_VELOCITY=100
X_MIN_QUOTE_VELOCITY=25
X_MIN_REPOST_VELOCITY=75
X_MIN_VIEWS_PER_HOUR=50000
X_MIN_ENGAGEMENT_PER_HOUR=250
X_MIN_ENGAGEMENT_ACCELERATION=500
X_MIN_ATTENTION_SHAPE_SCORE=25000
X_MIN_SCOUT_SHAPE_SCORE=500
X_MAX_SCOUT_POSTS_PER_QUERY=1
X_MAX_POST_AGE_HOURS=12
X_MAX_STRONG_POST_AGE_HOURS=48
X_RESULTS_PER_QUERY=25
